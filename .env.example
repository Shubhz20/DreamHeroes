# =============================================================
# Copy this file to .env and fill in values for local development.
# For production deployment on Vercel + Supabase, configure the
# same keys in your Vercel project settings → Environment Variables.
# =============================================================

# --- Database ---
# Local default: SQLite file (works out-of-the-box, zero setup).
DATABASE_URL="file:./dev.db"

# For Supabase (production):
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?schema=public"
# (Change the `provider` in prisma/schema.prisma from `sqlite` to `postgresql`
#  before running `prisma db push` against Supabase.)

# --- Authentication ---
# 32+ char random string used to sign JWT session tokens.
JWT_SECRET="dev-secret-please-change-me-in-production-32bytes-minimum"

# --- Stripe (test mode) ---
# Leave ALL Stripe keys blank to use the mock payment path (no card needed).
# Fill them in to exercise the real Stripe Checkout + webhooks flow.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Stripe Price IDs — create one Product with two recurring Prices in the
# Stripe Dashboard (Monthly £9.99 and Yearly £99.00 are good defaults) and
# paste the `price_...` ids below.
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_YEARLY=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Comma-separated emails that are auto-elevated to admin on signup.
ADMIN_EMAILS="admin@digitalheroes.test"
